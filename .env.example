# ══════════════════════════════════════════════════════════════════
#  Mi Negocio POS — Fork Multi-tienda
#  Copiá este archivo como .env y completá los valores
# ══════════════════════════════════════════════════════════════════

APP_NAME="Mi Negocio"
APP_ENV=production
APP_KEY=                        # php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=http://localhost:8000   # Cambiar por la IP local: http://192.168.1.XX:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ── Base de datos ─────────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_DATABASE= se resuelve automático a database/database.sqlite
# Si querés ruta explícita:
# DB_DATABASE=/ruta/absoluta/al/proyecto/database/database.sqlite

# ── Cache, sesiones y colas ───────────────────────────────────────
# En hardware limitado (Raspberry Pi, PC vieja) usar file/sync siempre
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=480            # 8 horas — ideal para turno completo
QUEUE_CONNECTION=sync

# ── Logging ───────────────────────────────────────────────────────
LOG_CHANNEL=single
LOG_LEVEL=error                 # En producción solo errores graves
# LOG_LEVEL=debug               # Descomentar para diagnosticar problemas

# ── Mail (no se usa por ahora, dejar así) ─────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="noreply@minegocio.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Storage ───────────────────────────────────────────────────────
FILESYSTEM_DISK=local           # Logos e imágenes en storage/app/public

# ══════════════════════════════════════════════════════════════════
#  MULTI-TIENDA
# ══════════════════════════════════════════════════════════════════

# false (default): solo vos creás tiendas via tinker/seeder
#                  el cliente no ve la opción en el sistema
#
# true:            el superadmin del cliente puede crear/editar/eliminar
#                  tiendas desde el panel — cobrar este upgrade
#
ALLOW_TIENDA_MANAGEMENT=false

# ══════════════════════════════════════════════════════════════════
#  BACKUP AUTOMÁTICO
# ══════════════════════════════════════════════════════════════════
# El scheduler hace backup 2 veces por día (ver console.php)
# Asegurate de tener el cron configurado:
#   * * * * * cd /ruta/proyecto && php artisan schedule:run >> /dev/null 2>&1

# ══════════════════════════════════════════════════════════════════
#  CREDENCIALES INICIALES (cambiar antes de entregar al cliente)
# ══════════════════════════════════════════════════════════════════
#
#  superadmin  super@sistema.local     / super1234
#  admin       admin@minegocio.local   / admin1234
#  empleado    empleado@minegocio.local/ empleado1234
#
#  php artisan migrate:fresh --seed
